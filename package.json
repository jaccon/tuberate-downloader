{
  "name": "youtube-downloader",
  "version": "1.0.0",
  "description": "YouTube Video Downloader - Electron App",
  "author": "Tuberate",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.tuberate.downloader",
    "productName": "Tuberate Downloader",
    "icon": "assets/logotipo.png",
    "extraResources": [
      {
        "from": "bin/yt-dlp",
        "to": "bin/yt-dlp"
      }
    ],
    "mac": {
      "target": "dmg",
      "defaultArch": "x64"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
